{
  "name": "biserica-betel-reus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "node backend/src/server.mjs",
    "start": "node backend/src/server.mjs",
    "dev:backend": "node backend/src/server.mjs",
    "start:backend": "node backend/src/server.mjs",
    "minify:app": "terser frontend/public/js/app.js -c -m -o frontend/public/js/app.min.js",
    "minify:volley": "terser frontend/public/js/volley.js -c -m -o frontend/public/js/volley.min.js",
    "minify": "npm run minify:app && npm run minify:volley",
    "check": "node --check server.mjs && find backend/src frontend/public/js -name '*.mjs' -o -name '*.js' | xargs -I{} node --check {}"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "terser": "^5.48.0"
  }
}
